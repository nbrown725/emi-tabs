{
	"schemaVersion": 1,
	"id": "emitabs",
	"version": "${version}",
	"name": "EMI Tabs",
	"description": "Adds creative-mode tabs to the top of EMI's item index so you can filter the list by creative tab.",
	"authors": [
		"nbrown725"
	],
	"contact": {
		"homepage": "https://github.com/nbrown725/emi-tabs",
		"sources": "https://github.com/nbrown725/emi-tabs",
		"issues": "https://github.com/nbrown725/emi-tabs/issues"
	},
	"license": "MIT",
	"icon": "assets/emitabs/icon.png",
	"environment": "client",
	"entrypoints": {
		"main": [
			"com.nbrown725.emitabs.fabric.EmiTabsFabric"
		]
	},
	"mixins": [
		{
			"config": "emitabs.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.16.5",
		"minecraft": "~1.21.1",
		"java": ">=21",
		"emi": "*"
	}
}
